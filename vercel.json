{
  "rewrites": [
    {
      "source": "/verify/:id",
      "destination": "/verify.html"
    },
    {
      "source": "/api/verify",
      "destination": "/api/verify.js"
    }
  ],
  "headers": [
    {
      "source": "/verify/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
