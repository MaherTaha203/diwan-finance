{
  "rewrites": [
    {
      "source": "/verify/:id",
      "destination": "/verify.html"
    },
    {
      "source": "/api/verify",
      "destination": "/api/verify.js"
    }
  ],
  "headers": [
    {
      "source": "/verify/(.*)",
      "headers": [
        { "key": "X-Robots-Tag",         "value": "noindex, nofollow" },
        { "key": "X-Frame-Options",       "value": "DENY" },
        { "key": "X-Content-Type-Options","value": "nosniff" },
        { "key": "Cache-Control",         "value": "no-store, no-cache" }
      ]
    }
  ]
}

{
  "rewrites": [
    {
      "source": "/verify/:id",
      "destination": "/verify.html"
    },
    {
      "source": "/api/verify",
      "destination": "/api/verify.js"
    }
  ]
}
